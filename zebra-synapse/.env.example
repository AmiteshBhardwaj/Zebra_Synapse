# Supabase: Project Settings -> API -> Project URL and anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: set this only if auth email redirects must use a fixed origin.
# Otherwise the app will use the current browser origin automatically.
# VITE_SITE_URL=https://your-project.vercel.app
# Optional: inactivity timeout for browser sessions in milliseconds.
# Defaults to 900000 (15 minutes). Set a larger value only if your threat model requires it.
# VITE_AUTH_INACTIVITY_TIMEOUT_MS=900000
